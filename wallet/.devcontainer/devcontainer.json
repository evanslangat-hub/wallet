{
  "name": "wallet-devcontainer",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "wallet",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash",
    "editor.formatOnSave": true
  },
  "extensions": [
    "ms-dotnettools.csharp",
    "ms-dotnettools.vscode-dotnet-runtime",
    "ms-azuretools.vscode-docker",
    "esbenp.prettier-vscode",
    "dbaeumer.vscode-eslint"
  ],
  "postCreateCommand": "dotnet restore /workspace/wallet.csproj",
  "postStartCommand": "dotnet watch run --urls=http://+:8080;https://+:8081",
  "forwardPorts": [8080, 8081],
  "remoteUser": "vscode",
  "runArgs": ["--init"],
  "mounts": [
    "source=${localWorkspaceFolder}/.nuget,target=/home/vscode/.nuget,type=bind"
  ]
}
